{
  "name": "@typenx/addon-video-library",
  "version": "0.1.0",
  "description": "Typenx addon for self-hosted anime video source distribution.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/index.js",
    "start": "node dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@typenx/addon-ts-sdk": "file:../typenx-addon-TS-sdk"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "typenx",
    "addon",
    "anime",
    "video",
    "self-hosted"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/typenx/typenx-addon-video-library.git"
  },
  "license": "MIT"
}
